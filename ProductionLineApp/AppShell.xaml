<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProductionLineApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ProductionLineApp.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Production Line Monitor">

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="#1565C0" />
            <Setter Property="Shell.TabBarForegroundColor" Value="White" />
            <Setter Property="Shell.TabBarTitleColor" Value="White" />
            <Setter Property="Shell.TabBarUnselectedColor" Value="#90CAF9" />
        </Style>
    </Shell.Resources>

    <TabBar>
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Icon="tab_dashboard.png"
            Route="dashboard" />

        <ShellContent
            Title="Alerts"
            ContentTemplate="{DataTemplate views:NotificationLogsPage}"
            Icon="tab_alerts.png"
            Route="alerts" />

        <ShellContent
            Title="Lines"
            ContentTemplate="{DataTemplate views:LineStatusPage}"
            Icon="tab_lines.png"
            Route="lines" />

        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Icon="tab_settings.png"
            Route="settings" />
    </TabBar>
</Shell>
