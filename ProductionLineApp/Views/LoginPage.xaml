<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProductionLineApp.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ProductionLineApp.ViewModels"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1565C0" Offset="0" />
            <GradientStop Color="#003c8f" Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="0" VerticalOptions="Center">

            <!-- Logo / Icon area -->
            <Image
    Source="logo_en.svg"
    HeightRequest="200"
    WidthRequest="300"
    HorizontalOptions="Center"
    Aspect="AspectFit" />

            <!--<Label
                Text="MEAI Internal Application"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                 Margin="0,0,0,48"
                HorizontalTextAlignment="Center" />-->

            <!--<Label
                Text=""
                FontSize="18"
                TextColor="#90CAF9"
                HorizontalTextAlignment="Center"
                Margin="0,0,0,48" />-->

            <!-- Login Card -->
            <Frame
                CornerRadius="16"
                Padding="24"
                BackgroundColor="White"
                HasShadow="True"
                BorderColor="Transparent">

                <VerticalStackLayout Spacing="16">

                    <Label
                        Text="Sign In"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalTextAlignment="Center"
                        Margin="0,0,0,8" />

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email" Style="{StaticResource CaptionText}" FontAttributes="Bold" />
                        <Frame Padding="12,0" CornerRadius="8" BorderColor="{StaticResource DividerColor}" HasShadow="False">
                            <Entry
                                x:Name="EmailEntry"
                                Text="{Binding Email}"
                                Placeholder="your@email.com"
                                Keyboard="Email"
                                ReturnType="Next" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password" Style="{StaticResource CaptionText}" FontAttributes="Bold" />
                        <Frame Padding="12,0" CornerRadius="8" BorderColor="{StaticResource DividerColor}" HasShadow="False">
                            <Entry
                                Text="{Binding Password}"
                                Placeholder="••••••••"
                                IsPassword="True"
                                ReturnType="Done"
                                ReturnCommand="{Binding LoginCommand}" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Error message -->
                    <Frame
                        Padding="12"
                        CornerRadius="8"
                        BackgroundColor="#FFEBEE"
                        BorderColor="#FFCDD2"
                        HasShadow="False"
                        IsVisible="{Binding HasError}">
                        <Label
                            Text="{Binding ErrorMessage}"
                            TextColor="#C62828"
                            FontSize="13" />
                    </Frame>

                    <!-- Login button -->
                    <Button
                        Text="Sign In"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,8,0,0"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}" />

                    <!-- Loading indicator -->
                    <ActivityIndicator
                        IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}"
                        Color="{StaticResource Primary}"
                        HorizontalOptions="Center" />

                </VerticalStackLayout>
            </Frame>

            <Label
                Text="MEAI Internal Application v1.0"
                TextColor="#90CAF9"
                FontSize="12"
                HorizontalTextAlignment="Center"
                Margin="0,32,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
